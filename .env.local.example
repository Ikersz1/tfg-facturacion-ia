# Copia este archivo a .env.local y rellena con tu proyecto (Supabase → Settings → API).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Verifacti (opcional): API Key del NIF en panel Verifacti (vf_test_… pruebas, vf_prod_… producción).
# Si está definida, al emitir factura se llama POST https://api.verifacti.com/verifactu/create
# y hacen falta datos fiscales del emisor (/settings/fiscal) y NIF del cliente.
VERIFACTI_NIF_API_KEY=
# Opcional: por defecto https://api.verifacti.com
# VERIFACTI_API_BASE_URL=https://api.verifacti.com

# Opcional: solo si usas scripts con service_role. El panel usa la sesión del usuario (anon + JWT).
# Necesaria para el cron de Vercel que consulta estado Verifacti en segundo plano.
SUPABASE_SERVICE_ROLE_KEY=

# Cron Vercel (GET /api/cron/verifacti-status): Vercel envía Authorization: Bearer <CRON_SECRET> si defines esta variable en el proyecto.
CRON_SECRET=

# Asistente IA (/asistente): opcional. Sin clave funciona con reglas locales; con clave, OpenAI elige la consulta.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ASSISTANT_SKIP_POLISH=1

# Usuarios del panel: Supabase → Authentication → Users (crear usuario con email/contraseña para iniciar sesión en /login).
